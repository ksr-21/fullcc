rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isStaff() {
       return isSignedIn() && 
         exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         getUserData().tag in ['HOD/Dean', 'Director', 'Super Admin', 'Teacher'];
    }

    function isAdmin() {
       return isSignedIn() && 
         exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         getUserData().tag in ['HOD/Dean', 'Director', 'Super Admin'];
    }

    function isSuperAdmin() {
       return isSignedIn() && 
         exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         getUserData().tag == 'Super Admin';
    }

    // --- Collection Rules ---

    // USERS COLLECTION
    match /users/{userId} {
      allow read: if isSignedIn(); 
      allow create: if isOwner(userId) || isAdmin();
      allow update: if isOwner(userId) || isAdmin();
      // Allow deletion of the invite stub or self
      allow delete: if isOwner(userId) || isAdmin() || (isSignedIn() && resource.data.email == request.auth.token.email);
    }

    // INVITES COLLECTION
    match /invites/{inviteId} {
      // Allow staff to manage directory
      allow read, write: if isAdmin() || isStaff();
      
      // Allow new users to find their own invite (read access is safe as they are authenticated)
      allow read: if isSignedIn();
      allow list: if isSignedIn();
      allow delete: if isSignedIn() && (resource.data.email == request.auth.token.email);
    }

    // COLLEGES
    match /colleges/{collegeId} {
      allow read: if isSignedIn();
      allow create: if isSuperAdmin();
      // allow update for swap-migration and admin edits
      allow update: if isSignedIn(); 
      allow delete: if isSuperAdmin();
    }

    // POSTS
    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isOwner(resource.data.authorId) || isAdmin();
    }

    // GROUPS
    match /groups/{groupId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isOwner(resource.data.creatorId) || isAdmin();
    }

    // COURSES
    match /courses/{courseId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // NOTICES
    match /notices/{noticeId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isStaff();
    }

    // STORIES
    match /stories/{storyId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isOwner(resource.data.authorId) || isAdmin();
    }

    // CONVERSATIONS
    match /conversations/{conversationId} {
      allow read, write: if isSignedIn() && request.auth.uid in resource.data.participantIds;
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.participantIds;
    }
    
    // Catch-all
    match /{path=**} {
      allow read, write: if isSuperAdmin();
    }
  }
}